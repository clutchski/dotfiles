#!/usr/bin/env bash
set -euo pipefail

# Delete local branches (and their worktrees) that are merged into main
# or whose upstream has been deleted on the remote.

if ! command -v wt >/dev/null 2>&1; then
    echo "error: wt (worktrunk) is required but not installed"
    exit 1
fi

git fetch -p

main_branch=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's|^origin/||' || true)
main_branch=${main_branch:-main}

current=$(git symbolic-ref --quiet --short HEAD || true)

merged=$(git branch --merged "$main_branch" --format='%(refname:short)')
gone=$(git for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads/ \
    | awk '/\[gone\]/ {print $1}')

branches=$(printf '%s\n%s\n' "$merged" "$gone" \
    | awk 'NF' \
    | grep -vxF "$main_branch" \
    | grep -vxF "${current:-$main_branch}" \
    | sort -u || true)

if [ -z "$branches" ]; then
    echo "Nothing to clean up."
    exit 0
fi

echo "Delete these branches and their worktrees? [y/N]"
echo "$branches"
read -r confirm

if [[ "$confirm" =~ ^[Yy]$ ]]; then
    echo "$branches" | xargs wt remove --force --force-delete --yes
    echo "Cleanup complete."
else
    echo "Cancelled."
fi
